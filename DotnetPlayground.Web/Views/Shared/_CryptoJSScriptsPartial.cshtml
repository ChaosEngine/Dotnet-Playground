<environment include="Development">
	<script type="text/javascript">
		var libs2Load = ['../../lib/blueimp-md5/md5.min.js', 'shared.js'];
	</script>
	<script src="~/lib/blueimp-md5/md5.min.js"></script>
</environment>
<environment exclude="Development">
	<script type="text/javascript">
		var libs2Load = [];
	</script>
	<script src="https://unpkg.com/blueimp-md5@2.19.0/js/md5.min.js" integrity="sha256-ZNfe04jFYuS96eWM4gXl+gG5c0/NQ01Jbre0+/6bkn0=" crossorigin="anonymous"
			asp-fallback-src="~/lib/blueimp-md5/md5.min.js"
			asp-fallback-test="(window.md5 && libs2Load.push('https://unpkg.com/blueimp-md5@2.19.0/js/md5.min.js'))"></script>
	<script type="text/javascript">
		if(libs2Load.length <= 0)
		{
			libs2Load = ['../../lib/blueimp-md5/md5.min.js', 'shared.min.js'];
		}
		else
			libs2Load.push('shared.min.js');
	</script>
</environment>
